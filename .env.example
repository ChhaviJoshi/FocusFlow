# =============================================================================
# FocusFlow — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# === Server ===
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# === Google OAuth 2.0 ===
# Get these from Google Cloud Console → APIs & Services → Credentials
# Make sure to add http://localhost:3001/auth/google/callback as an Authorized Redirect URI
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# === Gemini AI ===
# Get from Google AI Studio → https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# === PostgreSQL ===
# Matches docker-compose.yml defaults
DATABASE_URL=postgresql://focusflow:focusflow_dev@localhost:5432/focusflow

# === Redis ===
REDIS_URL=redis://localhost:6379

# === Session ===
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-64-char-secret

# === Encryption Key (for storing OAuth tokens at rest) ===
# MUST be exactly 32 bytes (64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change-me-to-a-random-64-hex-string-exactly-32-bytes
